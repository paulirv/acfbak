# Runner environment secrets (the transfer process, run outside the Worker).
#
# Copy to `.env` (gitignored) and fill in real values, or supply these as
# CI/job secrets (e.g. GitHub Actions secrets). Never commit `.env` or real
# credentials.

# --- Acquia Cloud API (pull the latest existing backup) ---
ACQUIA_API_KEY=""
ACQUIA_API_SECRET=""

# --- Cloudflare R2, S3-compatible API (stream the dump into the bucket) ---
# Account ID is in the Cloudflare dashboard URL / R2 overview.
R2_ACCOUNT_ID=""
# Create an R2 API token (Object Read & Write) and use its access key pair.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# --- Cloudflare Queues HTTP pull consumer (receive the Worker's handoff) ---
# Only needed for the queue-driven runner: `npm run runner -- --consume`.
# Same Cloudflare account as R2_ACCOUNT_ID.
CF_ACCOUNT_ID=""
# API token with the "Queues" permission (read + edit) to pull and ack messages.
CF_API_TOKEN=""
# The handoff queue's id (UUID) — from `wrangler queues list` or the dashboard.
CF_QUEUE_ID=""

# --- Per-run notifications (#12) ---
# Only needed when acfbak.config.json sets notifications.channel = "webhook".
# A Slack-compatible incoming-webhook URL ({ "text": ... } payload); Telegram or
# email work via any webhook relay. Leave unset for the default console channel.
NOTIFY_WEBHOOK_URL=""
