# Runner environment secrets (the transfer process, run outside the Worker).
#
# Copy to `.env` (gitignored) and fill in real values, or supply these as
# CI/job secrets (e.g. GitHub Actions secrets). Never commit `.env` or real
# credentials.

# --- Acquia Cloud API (pull the latest existing backup) ---
ACQUIA_API_KEY=""
ACQUIA_API_SECRET=""

# --- Cloudflare R2, S3-compatible API (stream the dump into the bucket) ---
# Account ID is in the Cloudflare dashboard URL / R2 overview.
R2_ACCOUNT_ID=""
# Create an R2 API token (Object Read & Write) and use its access key pair.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
